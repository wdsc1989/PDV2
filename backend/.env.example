# Copy to .env and adjust
# DATABASE_URL=sqlite:///./data/pdv.db
# DATABASE_URL=postgresql://pdv_user:YOUR_PASSWORD@localhost:5432/pdv_db
# SECRET_KEY=generate-with-openssl-rand-hex-32
# CORS_ORIGINS=["http://localhost:3000"]

# fal.ai — gerador de looks (item 4).
# Recomendado configurar pela UI: Administração -> Configuração fal.ai (Looks).
# As variáveis abaixo são apenas fallback opcional:
# FAL_KEY=your-fal-api-key
# FAL_MODEL=fal-ai/nano-banana/edit
